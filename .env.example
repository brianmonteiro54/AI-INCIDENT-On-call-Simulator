# ──────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente. Copie para .env.local (dev) e configure no painel da
# Vercel (produção). NUNCA comite valores reais — só este arquivo de exemplo.
# ──────────────────────────────────────────────────────────────────────────────

# ── Upstash Redis (grátis em upstash.com) — leaderboard + rate limit ──
# SECRETO (server-only). Sem isso, o leaderboard/rate-limit caem para storage
# em memória (zera a cada restart) — ok só em dev local.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Assinatura HMAC do envio de pontuação (anti-trapaça casual) ──
# Use uma string aleatória longa (ex.: `openssl rand -hex 32`). Defina o MESMO
# valor na Vercel. ⚠️ É NEXT_PUBLIC_ porque o navegador precisa assinar — então
# fica visível no JS do cliente; é "obstáculo", não segredo de verdade. Vazio =
# envios sem assinatura e o servidor pula a verificação (a proteção fica desligada).
NEXT_PUBLIC_SUBMIT_SECRET=

# ── URL pública do site (opcional) ──
# Usada para a imagem de compartilhamento (Open Graph) ter URL absoluta. Na
# Vercel é detectada sozinha (VERCEL_URL); defina aqui só em domínio próprio
# ou outro host. Ex: https://ai-incident.seudominio.com
NEXT_PUBLIC_SITE_URL=
