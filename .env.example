# Upstash Redis (free at upstash.com)
# Sem isso, leaderboard usa storage em memória (zera no restart)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# URL pública do site — usada pra deixar a imagem de compartilhamento (Open Graph)
# com URL absoluta. Na Vercel é detectada sozinha; em outros hosts (ex: Render),
# defina aqui pra que o card apareça certo no WhatsApp/X/LinkedIn.
# Ex: https://ai-incident.seudominio.com
NEXT_PUBLIC_SITE_URL=
